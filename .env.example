# Clawd 🦞 Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env - it contains sensitive information

# ──────────────────────────────────────────────
# LM Studio Configuration
# ──────────────────────────────────────────────
# URL where LM Studio is running (local by default)
LM_STUDIO_URL=http://localhost:1234/v1

# Model name to use (must be loaded in LM Studio)
# Examples: meta-llama-3.1-8b-instruct, mistral-7b, etc.
MODEL_NAME=meta-llama-3.1-8b-instruct

# ──────────────────────────────────────────────
# Telegram Bot (Optional)
# ──────────────────────────────────────────────
# Get your token from @BotFather on Telegram
# Only needed if using telegram_bot.py
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ──────────────────────────────────────────────
# Optional: Execution Customization
# ──────────────────────────────────────────────
# Command timeout in seconds (default: 120)
# CMD_TIMEOUT=120

# Maximum command timeout (default: 600)
# CMD_TIMEOUT_MAX=600

# ──────────────────────────────────────────────
# Optional: Reinforcement Learning
# ──────────────────────────────────────────────
# Enable RL policy layer (default: False)
# RL_ENABLED=false

# RL policy weight: 0.0 = LLM only, 1.0 = policy only (default: 0.0)
# RL_POLICY_WEIGHT=0.0
